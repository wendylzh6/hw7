# Copy this file to `gemini.env` and fill in your API keys.
# `gemini.env` is gitignored and not committed.

# --- Google Gemini (preferred if set) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- OpenAI (used if GEMINI_API_KEY is not set) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- ElevenLabs (optional: TTS + final video; omit to stop after narration JSON) ---
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
